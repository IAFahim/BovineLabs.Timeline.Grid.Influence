  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: 'All four DOTSTracks bind TargetsAuthoring on an ECS-pure body. The grid is a world-space 2D integer field (PlaneNormal=up -> XZ plane, CellSize=1). Prereq: InfluenceGridSettingsAuthoring lists BOTH Threat & Objective fields (a field NOT listed = silent no-op). WRITE/SHAPE = a RED hazard stamps the Threat field (value=author integer, no x100). COMPOSITE = a layered mound blob into Objective. FLOW STEERING reads the field gradient and moves the BLUE agent DIRECTLY (descend=flee, ascend=seek) = VISIBLE motion. QUERY bakes InfluenceQueryResult{Value,Direction,Cell,Valid} = NUMERIC read seam. FixedLength + Loop.'
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2180264, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
